<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8">

    <!-- ══ APP BAR ══════════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1B1F3B"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationContentDescription="Back"
            app:title="Expense Tracker"
            app:titleTextColor="#FFFFFF"
            app:subtitleTextColor="#8A9FD8" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══ MAIN SCROLL ══════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp">

            <!-- ── SUMMARY STRIP ────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Total (all time) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#1B1F3B">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL SPENT"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:textColor="#8A9FD8"/>
                        <TextView
                            android:id="@+id/tvTotalAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Period total (dynamic) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvPeriodLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THIS MONTH"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:textColor="#8E9BB5"/>
                        <TextView
                            android:id="@+id/tvPeriodAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#1B1F3B"/>
                        <TextView
                            android:id="@+id/tvPeriodCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 expenses"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ── TIME FILTER TABS ─────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tabDay"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Day"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/chip_unselected"
                        android:textColor="#555555"/>

                    <TextView
                        android:id="@+id/tabWeek"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Week"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/chip_unselected"
                        android:textColor="#555555"/>

                    <TextView
                        android:id="@+id/tabMonth"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Month"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/chip_selected"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tabYear"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="Year"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/chip_unselected"
                        android:textColor="#555555"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── PIE CHART CARD (Title-based) ──────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spending by Title"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1B1F3B"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPieEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Add expenses to see your spending breakdown"
                        android:textSize="12sp"
                        android:textColor="#BBBBBB"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone"/>

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"/>

                    <!-- Custom Legend -->
                    <LinearLayout
                        android:id="@+id/legendContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── BAR CHART CARD ─────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvBarTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Spending"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1B1F3B"/>

                        <TextView
                            android:id="@+id/tvBarSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="This month"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvBarEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No spending data yet"
                        android:textSize="12sp"
                        android:textColor="#BBBBBB"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone"/>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── EXPENSE LIST HEADER ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvListTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="This Month's Expenses"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1B1F3B"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteAll"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="🗑 Delete All"
                    android:textSize="11sp"
                    android:visibility="gone"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#FFEBEE"
                    android:textColor="#E53935"/>
            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No expenses yet.\nTap ＋ to add your first one."
                android:textSize="14sp"
                android:textColor="#BBBBBB"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="visible"/>

            <!-- ── EXPENSE RECYCLER LIST ───────────────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══ FAB ══════════════════════════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Add Expense"
        app:icon="@android:drawable/ic_input_add"
        app:backgroundTint="#1B1F3B"
        android:textColor="#FFFFFF"
        app:iconTint="#FFFFFF"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>