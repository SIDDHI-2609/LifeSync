<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- ══════════════════════════════════════════════
             CARD
        ══════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── DARK HEADER ──────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1B1F3B"
                    android:gravity="center"
                    android:paddingTop="36dp"
                    android:paddingBottom="28dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <!-- App logo circle -->
                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:background="@drawable/circle_profile_bg"
                        android:padding="13dp"
                        android:tint="#8A9FD8"
                        android:layout_marginBottom="16dp"
                        android:contentDescription="LifeSync logo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LifeSync"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.03"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back"
                        android:textSize="14sp"
                        android:textColor="#8A9FD8" />

                </LinearLayout>

                <!-- ── FORM BODY ────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <!-- ── EMAIL ───────────────────────────── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email address"
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="#8E9BB5"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#CCCCCC"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="you@example.com"
                            android:inputType="textEmailAddress"
                            android:imeOptions="actionNext"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/errEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter a valid email address"
                        android:textSize="11sp"
                        android:textColor="#E53935"
                        android:layout_marginBottom="14dp"
                        android:visibility="gone" />

                    <!-- ── PASSWORD ────────────────────────── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:startIconTint="#8E9BB5"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="#8E9BB5"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#CCCCCC"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Your password"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/errPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password cannot be empty"
                        android:textSize="11sp"
                        android:textColor="#E53935"
                        android:layout_marginBottom="4dp"
                        android:visibility="gone" />

                    <!-- Forgot password link -->
                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forgot password?"
                        android:textSize="12sp"
                        android:textColor="#4C6EF5"
                        android:textStyle="bold"
                        android:layout_gravity="end"
                        android:paddingTop="4dp"
                        android:paddingBottom="2dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginBottom="24dp" />

                    <!-- ── Firebase error banner ───────────── -->
                    <LinearLayout
                        android:id="@+id/layoutError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/error_banner_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:tint="#E53935"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="Error" />

                        <TextView
                            android:id="@+id/tvFirebaseError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="#C62828" />
                    </LinearLayout>

                    <!-- ── SIGN IN BUTTON ──────────────────── -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Sign In"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp"
                        app:backgroundTint="#1B1F3B"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="16dp" />

                    <!-- ── DIVIDER ──────────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="#EEEEEE" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  or  "
                            android:textSize="12sp"
                            android:textColor="#AAAAAA" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="#EEEEEE" />
                    </LinearLayout>

                    <!-- ── GOOGLE SIGN-IN (optional stub) ─── -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoogleSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Continue with Google"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        app:cornerRadius="14dp"
                        app:backgroundTint="#F8F8F8"
                        app:strokeColor="#DDDDDD"
                        app:strokeWidth="1dp"
                        app:icon="@android:drawable/ic_menu_search"
                        app:iconTint="#E53935"
                        app:iconGravity="textStart"
                        android:layout_marginBottom="20dp" />

                    <!-- ── SIGN UP LINK ─────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingTop="16dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F0F0"
                            android:layout_marginBottom="16dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Don't have an account?  "
                            android:textSize="13sp"
                            android:textColor="#8E9BB5" />

                        <TextView
                            android:id="@+id/tvSignUp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign up"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1B1F3B"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                </LinearLayout>
                <!-- end form body -->

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>