<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.activities.ThemeActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1B1F3B"
        app:titleTextColor="#FFFFFF"
        android:elevation="4dp"
        app:title="🎨  Theme"
        app:navigationIcon="@android:drawable/ic_menu_revert"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your appearance"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select a theme that suits you best"
            android:textSize="13sp"
            android:textColor="#8A90A4"
            android:layout_marginBottom="24dp" />

        <!-- ── LIGHT MODE CARD ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLightMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="#5C7CFA"
            app:cardBackgroundColor="?attr/colorSurface"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Light Preview Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:orientation="vertical"
                    android:background="#F4F6FA"
                    android:padding="10dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="14dp"
                        android:background="#FFFFFF"
                        android:layout_marginBottom="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="22dp"
                        android:background="#FFFFFF"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="22dp"
                        android:background="#FFFFFF"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="60dp"
                        android:layout_height="22dp"
                        android:background="#FFFFFF" />

                </LinearLayout>

                <!-- Label Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="☀️  Light"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/checkLightMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅"
                        android:textSize="16sp"
                        android:visibility="visible" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- ── DARK MODE CARD ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDarkMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="#E0E0E0"
            app:cardBackgroundColor="?attr/colorSurface"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Dark Preview Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:orientation="vertical"
                    android:background="#121212"
                    android:padding="10dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="14dp"
                        android:background="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="22dp"
                        android:background="#1E1E1E"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="22dp"
                        android:background="#1E1E1E"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="60dp"
                        android:layout_height="22dp"
                        android:background="#1E1E1E" />

                </LinearLayout>

                <!-- Label Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌙  Dark"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/checkDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅"
                        android:textSize="16sp"
                        android:visibility="invisible" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>


</LinearLayout>