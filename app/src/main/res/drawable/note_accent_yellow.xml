<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/note_accent_yellow.xml
     Default left accent bar color for note cards.
     The Java adapter overrides this with setBackgroundColor()
     to cycle through different colors per card. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFB300" />
    <corners android:radius="4dp" />
</shape>